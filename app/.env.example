# Адрес и порт RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
# Логин/пароль RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
# Имя очереди, в которую кладутся задачи сегментации
RABBITMQ_QUEUE_NAME=ml_task_queue

# Подключение к PostgreSQL
DB_HOST=database
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=db_name

# Название и описание сервиса в документации
APP_NAME="MRI Tumor Segmentation API"
APP_DESCRIPTION="API for MRI brain tumor segmentation and similar clinical cases"
API_VERSION=1.0
DEBUG=False

# Имя cookie, в которую кладется JWT-токен авторизации
COOKIE_NAME=MRI_ACCESS_TOKEN
# Секрет для подписи JWT.
SECRET_KEY=MY_SECRET_KEY

# Папка для загруженных МРТ и лимит размера одного файла в байтах (200 МБ)
UPLOAD_DIR=/svc/app/uploads
MAX_UPLOAD_BYTES=209715200

# Адрес векторной базы Qdrant и имя коллекции похожих случаев
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mri_tumor_cases


# Куда редиректит корневой маршрут / — публичный адрес UI
STREAMLIT_PUBLIC_URL=http://localhost:8501
