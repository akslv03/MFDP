# Корневой .env — используется сервисом postgres в docker-compose.
# Имя базы, пользователь и пароль для PostgreSQL. При первом старте
# Postgres создает базу и пользователя с этими значениями.
POSTGRES_DB=db_name
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Логин/пароль RabbitMQ (должны совпадать с теми же переменными в app/.env).
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
